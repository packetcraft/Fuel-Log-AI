{
  "env": {
    "browser": true,
    "es2021": true,
    "googleappsscript/googleappsscript": true
  },
  "extends": "eslint:recommended",
  "plugins": ["googleappsscript"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off"
  }
}
